# Database (port 5433 to avoid conflicts with local PostgreSQL on 5432)
DATABASE_URL="postgresql://gitlab_ai:changeme@localhost:5433/gitlab_ai"
POSTGRES_PASSWORD=changeme

# Auth
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=  # generate: openssl rand -base64 32

# Google SSO (optional — enables "Sign in with Google" on the login page).
# Only emails ending in @SSO_ALLOWED_DOMAIN can sign in via Google; first-time
# Google sign-ins land in the PENDING role and need admin approval.
# Leave all three blank to disable Google SSO and use credentials only.
AUTH_GOOGLE_ID=
AUTH_GOOGLE_SECRET=
SSO_ALLOWED_DOMAIN=  # e.g. fluz.app

# Encryption (for storing API keys at rest)
ENCRYPTION_KEY=  # generate: openssl rand -hex 32
