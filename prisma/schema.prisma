generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["fullTextSearchPostgres"]
}

datasource db {
  provider = "postgresql"
}

// ============================================================
// AUTH TABLES
// ============================================================

model User {
  id             String   @id @default(cuid())
  name           String?
  email          String   @unique
  hashedPassword String?
  role           Role     @default(MEMBER)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  sessions           Session[]
  conversations      Conversation[]
  messages           Message[]
  workflowExecutions WorkflowExecution[]
  automations        Automation[]
  teamMemberships    TeamMember[]

  @@index([email])
  @@index([role])
}

enum Role {
  OWNER
  ADMIN
  MEMBER
}

// ============================================================
// TEAMS
// ============================================================

model Team {
  id                   String   @id @default(cuid())
  name                 String
  slug                 String   @unique
  enabledIntegrations  String[] @default([]) // e.g. ["gitlab","jira","confluence"]
  createdAt            DateTime @default(now())
  updatedAt            DateTime @updatedAt

  members TeamMember[]

  @@index([slug])
}

model TeamMember {
  id       String   @id @default(cuid())
  teamId   String
  userId   String
  role     TeamRole @default(MEMBER)
  joinedAt DateTime @default(now())

  team Team @relation(fields: [teamId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([teamId, userId])
  @@index([teamId])
  @@index([userId])
}

enum TeamRole {
  OWNER
  ADMIN
  MEMBER
}

model Session {
  id           String   @id @default(cuid())
  sessionToken String   @unique
  userId       String
  expires      DateTime

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

model VerificationToken {
  identifier String
  token      String   @unique
  expires    DateTime

  @@unique([identifier, token])
}

// ============================================================
// APP SETTINGS (singleton: id is always "default")
// ============================================================

model AppSettings {
  id             String  @id @default("default")
  setupCompleted Boolean @default(false)

  // GitLab
  gitlabUrl     String?
  gitlabPat     String? // encrypted
  gitlabGroupId String?

  // GitHub
  githubUrl     String?  // e.g. https://github.com or GHE URL
  githubPat     String?  // encrypted
  githubOrgName String?

  // Jira
  jiraUrl      String?  // e.g. https://your-domain.atlassian.net
  jiraEmail    String?  // user email for basic auth
  jiraApiToken String?  // encrypted API token

  // Confluence
  confluenceUrl      String?  // e.g. https://your-domain.atlassian.net
  confluenceEmail    String?  // user email for basic auth
  confluenceApiToken String?  // encrypted API token

  // SharePoint (Microsoft Graph)
  sharepointTenantId     String?  // Azure AD tenant ID
  sharepointClientId     String?  // Azure AD app client ID
  sharepointClientSecret String?  // encrypted client secret

  // Resend (Email)
  resendApiKey    String?  // encrypted
  resendFromEmail String?  // e.g. "noreply@yourdomain.com"

  // AI Provider
  aiProvider    String @default("openrouter") // openrouter | openai | google | ollama | openwebui
  aiModel       String @default("anthropic/claude-sonnet-4")
  aiApiKey      String? // encrypted
  aiBaseUrl     String? // custom base URL for Ollama, Open WebUI, or any compatible endpoint

  updatedAt DateTime @updatedAt
}

// ============================================================
// GITLAB DATA
// ============================================================

model GitlabProject {
  id                String      @id @default(cuid())
  gitlabId          Int         @unique
  name              String
  pathWithNamespace String
  description       String?
  webUrl            String
  defaultBranch     String      @default("main")
  lastIndexedAt     DateTime?
  indexStatus       IndexStatus @default(PENDING)
  included          Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  files IndexedFile[]

  @@index([gitlabId])
  @@index([indexStatus])
}

enum IndexStatus {
  PENDING
  INDEXING
  INDEXED
  FAILED
}

model GithubProject {
  id                String      @id @default(cuid())
  githubId          Int         @unique
  name              String
  fullName          String      // owner/repo
  description       String?
  htmlUrl           String
  defaultBranch     String      @default("main")
  lastIndexedAt     DateTime?
  indexStatus       IndexStatus @default(PENDING)
  included          Boolean     @default(false)
  createdAt         DateTime    @default(now())
  updatedAt         DateTime    @updatedAt

  files IndexedFile[] @relation("GithubProjectFiles")

  @@index([githubId])
  @@index([indexStatus])
}

// ============================================================
// JIRA DATA
// ============================================================

model JiraProject {
  id            String      @id @default(cuid())
  jiraId        String      @unique // Jira project ID (e.g. "10001")
  key           String      // Jira project key (e.g. "PROJ")
  name          String
  description   String?
  webUrl        String
  lastIndexedAt DateTime?
  indexStatus   IndexStatus @default(PENDING)
  included      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  issues JiraIssue[]

  @@index([jiraId])
  @@index([indexStatus])
}

model JiraIssue {
  id          String   @id @default(cuid())
  projectId   String
  jiraId      String   @unique // Jira issue ID (e.g. "10042")
  key         String   // Jira issue key (e.g. "PROJ-123")
  summary     String
  description String?  @db.Text // plain text from ADF
  issueType   String   // Bug, Task, Story, Epic, etc.
  status      String   // To Do, In Progress, Done, etc.
  priority    String?
  assignee    String?
  reporter    String?
  labels      String[] // Jira labels
  webUrl      String
  content     String   @db.Text // full searchable text (summary + description + comments)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  project JiraProject @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([projectId, key])
  @@index([projectId])
  @@index([key])
  @@index([issueType])
  @@index([status])
}

// ============================================================
// CONFLUENCE DATA
// ============================================================

model ConfluenceSpace {
  id            String      @id @default(cuid())
  confluenceId  String      @unique // Confluence space ID
  key           String      // Space key (e.g. "ENG")
  name          String
  description   String?
  webUrl        String
  lastIndexedAt DateTime?
  indexStatus   IndexStatus @default(PENDING)
  included      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  pages ConfluencePage[]

  @@index([confluenceId])
  @@index([indexStatus])
}

model ConfluencePage {
  id           String   @id @default(cuid())
  spaceId      String
  confluenceId String   @unique // Confluence page ID
  title        String
  webUrl       String
  content      String   @db.Text // plain text for search
  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  space ConfluenceSpace @relation(fields: [spaceId], references: [id], onDelete: Cascade)

  @@unique([spaceId, confluenceId])
  @@index([spaceId])
  @@index([title])
}

// ============================================================
// SHAREPOINT DATA
// ============================================================

model SharePointSite {
  id            String      @id @default(cuid())
  siteId        String      @unique // Microsoft Graph site ID
  name          String
  displayName   String
  webUrl        String
  lastIndexedAt DateTime?
  indexStatus   IndexStatus @default(PENDING)
  included      Boolean     @default(false)
  createdAt     DateTime    @default(now())
  updatedAt     DateTime    @updatedAt

  files SharePointFile[]

  @@index([siteId])
  @@index([indexStatus])
}

model SharePointFile {
  id         String   @id @default(cuid())
  siteId     String
  driveItemId String  @unique // Microsoft Graph drive item ID
  name       String
  path       String   // folder path within the drive
  mimeType   String?
  webUrl     String
  sizeBytes  Int
  content    String   @db.Text // extracted plain text
  sha        String?  // eTag for change detection
  indexedAt   DateTime @default(now())

  site SharePointSite @relation(fields: [siteId], references: [id], onDelete: Cascade)

  @@unique([siteId, driveItemId])
  @@index([siteId])
  @@index([name])
}

model IndexedFile {
  id              String   @id @default(cuid())
  projectId       String?
  githubProjectId String?
  filePath        String
  fileName        String
  language        String?
  content         String   @db.Text
  sizeBytes       Int
  sha             String
  indexedAt        DateTime @default(now())

  project       GitlabProject? @relation(fields: [projectId], references: [id], onDelete: Cascade)
  githubProject GithubProject? @relation("GithubProjectFiles", fields: [githubProjectId], references: [id], onDelete: Cascade)

  @@unique([projectId, filePath])
  @@unique([githubProjectId, filePath])
  @@index([projectId])
  @@index([githubProjectId])
  @@index([fileName])
  @@index([language])
}

// ============================================================
// CHAT
// ============================================================

model Conversation {
  id              String   @id @default(cuid())
  title           String?
  userId          String
  projectIds      String[]
  projectBranches Json?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user               User                @relation(fields: [userId], references: [id], onDelete: Cascade)
  messages           Message[]
  workflowExecutions WorkflowExecution[]
  fileChanges        FileChange[]

  @@index([userId])
  @@index([updatedAt])
}

model Message {
  id             String      @id @default(cuid())
  conversationId String
  userId         String?
  role           MessageRole
  content        String      @db.Text
  codeReferences Json?
  createdAt      DateTime    @default(now())

  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id])

  @@index([conversationId])
  @@index([createdAt])
}

enum MessageRole {
  USER
  ASSISTANT
  SYSTEM
}

// ============================================================
// WORKFLOWS
// ============================================================

model Workflow {
  id          String   @id @default(cuid())
  name        String
  description String?
  isDefault   Boolean  @default(false)
  isActive    Boolean  @default(true)
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  steps      WorkflowStep[]
  executions WorkflowExecution[]

  @@index([isActive])
}

model WorkflowStep {
  id         String           @id @default(cuid())
  workflowId String
  name       String
  type       WorkflowStepType
  order      Int
  config     Json?

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, order])
  @@index([workflowId])
}

enum WorkflowStepType {
  PLANNING
  PROGRAMMING
  COMMIT
}

model WorkflowExecution {
  id               String                  @id @default(cuid())
  workflowId       String
  conversationId   String
  userId           String
  currentStepOrder Int                     @default(0)
  status           WorkflowExecutionStatus @default(IN_PROGRESS)
  planText         String?                 @db.Text
  commitBranch     String?
  commitMessage    String?
  commitResult     Json?
  createdAt        DateTime                @default(now())
  updatedAt        DateTime                @updatedAt

  workflow     Workflow     @relation(fields: [workflowId], references: [id])
  conversation Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id])
  fileChanges  FileChange[]

  @@index([conversationId])
  @@index([userId])
  @@index([status])
}

enum WorkflowExecutionStatus {
  IN_PROGRESS
  COMPLETED
  FAILED
  CANCELLED
}

model FileChange {
  id              String           @id @default(cuid())
  executionId     String?
  conversationId  String?
  projectId       String
  filePath        String
  originalContent String           @db.Text
  modifiedContent String           @db.Text
  language        String?
  status          FileChangeStatus @default(PENDING)
  createdAt       DateTime         @default(now())
  updatedAt       DateTime         @updatedAt

  execution    WorkflowExecution? @relation(fields: [executionId], references: [id], onDelete: Cascade)
  conversation Conversation?      @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@unique([executionId, projectId, filePath])
  @@unique([conversationId, projectId, filePath])
  @@index([executionId])
  @@index([conversationId])
}

enum FileChangeStatus {
  PENDING
  ACCEPTED
  REJECTED
  COMMITTED
}

// ============================================================
// CUSTOM MCP SERVERS
// ============================================================

model McpServer {
  id        String  @id @default(cuid())
  name      String
  url       String  // MCP server endpoint (SSE / Streamable HTTP)
  apiKey    String? // encrypted Bearer token
  headers   Json?   // additional custom headers (values encrypted)
  enabled   Boolean @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([enabled])
}

// ============================================================
// AUTOMATIONS (scheduled AI cron jobs)
// ============================================================

model Automation {
  id             String   @id @default(cuid())
  title          String
  instructions   String   @db.Text
  cronExpression String   @default("0 * * * *") // standard cron (default: every hour)
  scheduleType   String   @default("interval")  // interval | daily | weekly | custom
  scheduleConfig Json?    // UI state: { intervalMinutes?, timeOfDay?, daysOfWeek? }
  dataSources     String[] @default([])           // e.g. ["jira","confluence","sharepoint","gitlab","github"]
  emailRecipients String[] @default([])          // email addresses to send results to (requires resend)
  enabled         Boolean  @default(true)
  lastRunAt      DateTime?
  userId         String
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  user User             @relation(fields: [userId], references: [id], onDelete: Cascade)
  runs AutomationRun[]

  @@index([userId])
  @@index([enabled])
}

model AutomationRun {
  id           String              @id @default(cuid())
  automationId String
  status       AutomationRunStatus @default(RUNNING)
  response     String?             @db.Text
  error        String?             @db.Text
  startedAt    DateTime            @default(now())
  completedAt  DateTime?

  automation Automation @relation(fields: [automationId], references: [id], onDelete: Cascade)

  @@index([automationId])
  @@index([startedAt])
}

enum AutomationRunStatus {
  RUNNING
  SUCCESS
  FAILED
}
